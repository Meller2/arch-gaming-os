# Force LF line endings for all text files
* text=auto eol=lf

# Explicit LF for script and config files
*.sh text eol=lf
*.conf text eol=lf
*.jsonc text eol=lf
*.json text eol=lf
*.desktop text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.py text eol=lf
*.gitkeep text eol=lf

# Binary files - don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.zst binary
*.iso binary
*.db binary
